#include<stdio.h>

void password();
void leap_year();

int main()
{
    password();
    return 0;
}

void password()
{
    int pass;
    printf("Enter the password: ");
    scanf("%d", &pass);

    if(pass == 12407)
    {
        printf("Password is correct\n");
        leap_year();
    }
    else
    {
        printf("Incorrect password\n");
    }
}

void leap_year()
{
    int year;

    printf("Enter the year: ");
    scanf("%d", &year);

    if((year % 400 == 0) || (year % 4 == 0 && year % 100 != 0))
    {
        printf("Year is a leap year");
    }
    else
    {
        printf("Year is not a leap year");
    }
}
